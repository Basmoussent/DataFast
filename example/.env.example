# CREEM payment keys
# Get from https://creem.io/dashboard/api-keys
CREEM_API_KEY=creem_test_your_key_here
CREEM_WEBHOOK_SECRET=your_webhook_secret_here

# DataFast analytics
# Get from https://app.datafast.io/settings/api
DATAFAST_API_KEY=your_datafast_api_key_here

# Product to sell — create one in your CREEM dashboard
CREEM_PRODUCT_ID=prod_your_product_id_here

# DataFast site ID — get from https://app.datafast.io/settings
NEXT_PUBLIC_DATAFAST_SITE_ID=your_datafast_site_id_here

# Your app's public domain (used by the DataFast tracking script to filter events)
# For local dev with a tunnel, set this to your tunnel domain (e.g. xyz.trycloudflare.com)
NEXT_PUBLIC_DATAFAST_DOMAIN=your-domain.com

# App URL (used for success redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000
